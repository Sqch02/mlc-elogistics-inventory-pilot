# ===========================================
# MLC E-Logistics Inventory Pilot
# Environment Variables Configuration
# ===========================================

# -------------------------------------------
# SUPABASE (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key for admin operations (server-side only)
# WARNING: Never expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------
# SENDCLOUD (Required for production)
# Get these from: https://panel.sendcloud.sc/settings/api-keys/
# -------------------------------------------

# Set to "true" for local development with mock data
SENDCLOUD_USE_MOCK=true

# Real Sendcloud credentials (required when SENDCLOUD_USE_MOCK=false)
SENDCLOUD_API_KEY=your-sendcloud-api-key
SENDCLOUD_SECRET=your-sendcloud-secret

# Webhook secret for real-time updates from Sendcloud
# Get this from: Sendcloud Panel > Settings > Integrations > Webhooks
# REQUIRED in production: the webhook endpoint fails closed (rejects with HTTP 500)
# when no secret is configured. Leaving this empty does NOT skip validation, it
# breaks reception of all Sendcloud webhooks.
SENDCLOUD_WEBHOOK_SECRET=your-sendcloud-webhook-secret

# -------------------------------------------
# APPLICATION
# -------------------------------------------

# Public URL of the application
# - Local development: http://localhost:3000
# - Render: https://mlc-inventory.onrender.com (auto-set)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------
# CRON & SECURITY (Required for Render)
# -------------------------------------------

# Secret for authenticating cron job requests
# Generate with: openssl rand -hex 32
# On Render: auto-generated via render.yaml
CRON_SECRET=your-random-secret-for-cron-jobs

# Maximum Sendcloud pages fetched per resource and tenant during one cron run.
# Default: 2 (~200 rows at 100/page), hard-capped at 50.
# WARNING: monter cette valeur (ex. 10) a sature l'I/O disque Supabase le 13/07/2026
# (le feed integration-shipments est non-incremental et re-ecrit tout a chaque tick).
# Ne PAS augmenter sans confirmer de la marge I/O. Pour rattraper un backlog, utiliser
# la reconciliation, pas ce budget de pages.
SENDCLOUD_CRON_MAX_PAGES=2

# --- OPERATIONS ---
# Frein d'urgence du cron: mettre SYNC_PAUSED=true met la sync en pause instantanement
# (sans redeploiement); retirer la variable la relance.
# SYNC_PAUSED=false

# Phase 2 auto-fix foundations. Fail closed: both values must be exact before
# detection/worker activity is possible. This release remains simulated only.
AUTO_FIX_PAUSED=true
AUTO_FIX_DRY_RUN_ENABLED=false
# Candidates queued from the current bounded sync batch (1..100, default 50).
AUTO_FIX_DRY_RUN_ENQUEUE_CAP=50
# Global worker time budget in milliseconds (1000..45000, default 20000).
AUTO_FIX_DRY_RUN_BUDGET_MS=20000

# Secret HMAC de signature du cookie de cache profil (fast-auth). Doit etre defini en
# prod, stable, >=32 chars aleatoires. S'il change, tous les caches profil sont invalides.
# COOKIE_SIGNING_SECRET=

# -------------------------------------------
# RENDER-SPECIFIC (Auto-set by Render)
# -------------------------------------------
# These are automatically configured when deploying to Render
# Do not set manually

# RENDER_EXTERNAL_URL=https://mlc-inventory.onrender.com

# -------------------------------------------
# SENTRY (Error Tracking - Optional)
# Get these from: https://sentry.io/settings/
# -------------------------------------------

# Client-side DSN (public)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# Server-side DSN
SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# Organization and project for source maps (optional)
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# Auth token for uploading source maps (optional)
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# -------------------------------------------
# DEPLOYMENT CHECKLIST
# -------------------------------------------
# Before deploying to Render, ensure:
# 1. Supabase project is created and configured
# 2. RLS policies are enabled on all tables
# 3. Sendcloud API credentials are valid
# 4. CRON_SECRET is set (or auto-generated)
# 5. Database migrations are applied
